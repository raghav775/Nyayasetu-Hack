# =============================================
# NyayaSetu — Environment Configuration
# Copy this file to .env and fill in values
# =============================================

# Groq API — free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — offline fallback, runs locally
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# JWT — run: python utils/generate_keys.py to get these
JWT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AES-256 Encryption — run: python utils/generate_keys.py to get this
ENCRYPTION_KEY=change_this_to_a_fernet_key

# Database — SQLite, free, no setup needed
DATABASE_URL=sqlite:///./nyayasetu.db

# ChromaDB — local vector store
CHROMA_DB_PATH=./chroma_db

# Data paths
DRAFTS_DATA_PATH=../data/drafts
